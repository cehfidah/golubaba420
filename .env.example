# Environment Variables Template
# Copy this file to .env.local and fill in your values

# LeakOSINT API Token
# Get your token from https://leakosintapi.com/
LEAKOSINT_API_TOKEN=your_api_token_here

# Search PIN (server-side only)
SEARCH_PIN=your_6_digit_pin_here

# Secret key used to sign search auth cookies
SEARCH_AUTH_SECRET=replace_with_a_long_random_secret

# Optional: Custom API URL (default: https://leakosintapi.com/)
# LEAKOSINT_API_URL=https://leakosintapi.com/
